# Copy to .env (gitignored) and adjust per environment.
# EXPO_PUBLIC_* vars are inlined into the bundle at build time by the Expo CLI.

# Base URL of the JouwPrivacy BFF (no trailing slash, no /v1 - the client adds
# the API version). Defaults to the production URL when unset. Point a dev build
# at a staging or local backend here; it must be https (a local dev host may use
# http). The app always talks to a real backend - there is no mock/offline mode.
EXPO_PUBLIC_API_URL=https://api.jouwprivacy.com
