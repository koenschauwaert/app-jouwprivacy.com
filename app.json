{
  "expo": {
    "name": "JouwPrivacy",
    "slug": "jouwprivacy-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "scheme": "jouwprivacy",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.jouwprivacy.app",
      "buildNumber": "12",
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Gebruik Face ID om de app snel en veilig te ontgrendelen."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jouwprivacy.app",
      "versionCode": 12,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1530"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "backgroundColor": "#0B0B0F",
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      "expo-asset",
      "expo-font",
      "./plugins/withCleanUpdatesManifest"
    ]
  }
}
